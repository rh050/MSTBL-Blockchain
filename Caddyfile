# MSTBL Blockchain - Full Caddy Configuration
# Migrated from GCP: February 1, 2026
# Updated: Frontend now local

rpc.stbl.mstbl.com {
    reverse_proxy localhost:26657
}

api.stbl.mstbl.com {
    @oldpath path /wasm/v1/*
    handle @oldpath {
        rewrite * /cosmwasm{uri}
        reverse_proxy localhost:1317
    }

    # Backend API endpoints
    @backend path /api/treasury/* /api/purchase/*
    handle @backend {
        reverse_proxy localhost:3002
    }

    reverse_proxy localhost:1317
}

grpc.stbl.mstbl.com {
    reverse_proxy h2c://localhost:9090
}

mstbl.com {
    reverse_proxy localhost:3000
}

app.stbl.mstbl.com {
    reverse_proxy localhost:3000
}
